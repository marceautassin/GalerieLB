---
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import LayoutPrincipal from '../../layouts/LayoutPrincipal.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CarteOeuvre from '../../components/CarteOeuvre.astro';
import SectionLiensRelies from '../../components/SectionLiensRelies.astro';
import RichText from '../../components/RichText.astro';
import { fetchExpositions, fetchAPropos } from '../../lib/strapi-client';
import { formatDateFr } from '../../lib/format';
import { url } from '../../lib/base-url';
import { FICHE_VISUEL } from '../../lib/image-presets';
import { buildExhibitionEventSchema, getSiteUrl, stripHtml } from '../../lib/seo-utils';

export const getStaticPaths: GetStaticPaths = async () => {
  const expositions = await fetchExpositions();
  return expositions.map((exposition) => ({
    params: { slug: exposition.slug },
    props: { exposition },
  }));
};

const { exposition } = Astro.props;
const visuels = exposition.visuels ?? [];
const visuelPrincipal = visuels[0];
const oeuvres = exposition.oeuvres ?? [];

// Artistes déduits des oeuvres (pas de relation directe Expo ↔ Artiste)
const artistesUniques = [...new Map(
  oeuvres
    .map((o) => o.artiste)
    .filter(Boolean)
    .map((a) => [a!.id, a!]),
).values()];

const artistesLiens = artistesUniques.map((a) => ({
  label: a.nom,
  href: url(`/artistes/${a.slug}`),
}));

const dates = exposition.dateFin
  ? `Du ${formatDateFr(exposition.dateDebut)} au ${formatDateFr(exposition.dateFin)}`
  : `Depuis le ${formatDateFr(exposition.dateDebut)}`;

function truncateAtWord(text: string, maxLen: number): string {
  if (text.length <= maxLen) return text;
  const truncated = text.slice(0, maxLen);
  const lastSpace = truncated.lastIndexOf(' ');
  return (lastSpace > 0 ? truncated.slice(0, lastSpace) : truncated) + '…';
}

const descParts = [exposition.titre, dates];
if (exposition.preface) descParts.push(stripHtml(exposition.preface));
const description = truncateAtWord(descParts.join(' — '), 160);

const breadcrumbItems = [
  { label: 'Accueil', href: url('/') },
  { label: 'Expositions', href: url('/expositions') },
  { label: exposition.titre },
];

const apropos = await fetchAPropos();
const siteUrl = getSiteUrl(Astro.site);
const schema = buildExhibitionEventSchema({ siteUrl, exposition, apropos });
---

<LayoutPrincipal
  title={`${exposition.titre} — Galerie Louis Barrand`}
  description={description}
  ogImage={visuelPrincipal?.url}
  schema={schema}
>
  <article class="fiche-exposition-page container--edge">
    <Breadcrumb items={breadcrumbItems} />

    <header class="fiche-exposition-header">
      <h1>{exposition.titre}</h1>
      <p class="fiche-exposition-dates">{dates}</p>
    </header>

    {visuels.length > 0 && (
      <div class="fiche-exposition-visuels">
        {visuels.map((v, i) => (
          <div class="fiche-exposition-visuel fiche-exposition-mur">
            <Image
              src={v.url}
              alt={v.alternativeText ?? exposition.titre}
              width={v.width}
              height={v.height}
              widths={FICHE_VISUEL.widths}
              sizes={FICHE_VISUEL.sizes}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
            />
          </div>
        ))}
      </div>
    )}

    {exposition.preface && (
      <div class="fiche-exposition-preface">
        <RichText content={exposition.preface} />
      </div>
    )}

    <a href={url(`/contact?exposition=${exposition.slug}`)} class="btn-primary cta-contact">
      Prendre rendez-vous
    </a>

    {oeuvres.length > 0 && (
      <section class="fiche-exposition-oeuvres">
        <h2>Oeuvres présentées</h2>
        <ul class="grille-oeuvres">
          {oeuvres.map((oeuvre) => (
            <li>
              <CarteOeuvre oeuvre={oeuvre} />
            </li>
          ))}
        </ul>
      </section>
    )}

    {artistesLiens.length > 0 && (
      <SectionLiensRelies
        titre="Artistes"
        items={artistesLiens}
        voirToutHref={url('/artistes')}
      />
    )}
  </article>
</LayoutPrincipal>

<style>
  .fiche-exposition-page {
    padding-bottom: var(--space-2xl);
  }

  .fiche-exposition-header {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .fiche-exposition-dates {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }

  .fiche-exposition-visuels {
    display: grid;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .fiche-exposition-visuel {
    overflow: hidden;
  }

  .fiche-exposition-mur {
    background: var(--color-mur);
    padding: var(--space-lg);
    max-width: 1000px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .fiche-exposition-mur {
      padding: var(--space-2xl);
    }
  }

  .fiche-exposition-visuel img {
    /* `max-width` + `width: auto` permet aux images portrait de garder leur
       ratio naturel sans être étirées à toute la largeur du mur ;
       `max-height: 80vh` cap la hauteur pour les visuels très hauts. */
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    display: block;
    margin-inline: auto;
  }

  .cta-contact {
    display: inline-block;
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .fiche-exposition-preface {
    margin-bottom: var(--space-2xl);
    max-width: 75ch;
  }

  .fiche-exposition-oeuvres {
    margin-bottom: var(--space-2xl);
  }

  .fiche-exposition-oeuvres h2 {
    margin-bottom: var(--space-lg);
  }

  .grille-oeuvres {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .grille-oeuvres {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .grille-oeuvres {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
