---
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import CarteOeuvre from '../components/CarteOeuvre.astro';
import { fetchOeuvres, fetchAPropos } from '../lib/strapi-client';
import { url } from '../lib/base-url';

const acquisitionsRecentes = await fetchOeuvres({ sort: 'createdAt:desc', limit: 8 });
const apropos = await fetchAPropos();
const vuesGalerie = apropos?.vuesGalerie ?? [];
---

<LayoutPrincipal
  title="Galerie Louis Barrand — Tableaux, Dessins, Estampes XIXe-XXe"
  description="Galerie d'art spécialisée dans la redécouverte d'artistes oubliés des XIXe et XXe siècles. Découvrez les dernières acquisitions, expositions et artistes."
>
  <section class="hero">
    <h1>Galerie Louis Barrand</h1>
    <hr class="hero-sep" />
    <p>Tableaux — Dessins — Estampes XIX-XXème</p>
  </section>

  {vuesGalerie.length > 0 && (
    <div class="bandeau-galerie" aria-hidden="true">
      <div class="bandeau-track">
        {[...vuesGalerie, ...vuesGalerie].map((img, i) => (
          <div class="bandeau-item">
            <img
              src={img.url}
              alt=""
              loading={i < vuesGalerie.length ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>
    </div>
  )}

  {acquisitionsRecentes.length > 0 && (
    <section class="acquisitions-recentes">
      <h2>Acquisitions récentes</h2>
      <ul class="grille-oeuvres">
        {acquisitionsRecentes.map((oeuvre) => (
          <li>
            <CarteOeuvre oeuvre={oeuvre} />
          </li>
        ))}
      </ul>
      <div class="voir-tout">
        <a href={url('/oeuvres')} class="btn-primary">Voir toutes les œuvres</a>
      </div>
    </section>
  )}
</LayoutPrincipal>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-4xl) 0 var(--space-3xl);
  }

  .hero h1 {
    margin-bottom: var(--space-md);
  }

  .hero-sep {
    width: 48px;
    border: none;
    border-top: 1px solid var(--color-text);
    margin-bottom: var(--space-md);
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }

  /* Bandeau déroulant */
  .bandeau-galerie {
    overflow: hidden;
    width: 100%;
    margin-bottom: var(--space-4xl);
  }

  .bandeau-track {
    display: flex;
    gap: var(--space-md);
    width: max-content;
    animation: defilement 40s linear infinite;
  }

  .bandeau-track:hover {
    animation-play-state: paused;
  }

  .bandeau-item {
    flex-shrink: 0;
    height: 280px;
    width: auto;
    overflow: hidden;
  }

  .bandeau-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
  }

  @keyframes defilement {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (min-width: 768px) {
    .bandeau-item {
      height: 360px;
    }
  }

  /* Acquisitions récentes */
  .acquisitions-recentes {
    padding-bottom: var(--space-4xl);
  }

  .acquisitions-recentes h2 {
    margin-bottom: var(--space-xl);
  }

  .grille-oeuvres {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .grille-oeuvres {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .grille-oeuvres {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .voir-tout {
    text-align: center;
    margin-top: var(--space-2xl);
  }
</style>
