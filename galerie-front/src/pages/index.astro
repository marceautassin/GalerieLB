---
import { Image } from 'astro:assets';
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import CarteOeuvre from '../components/CarteOeuvre.astro';
import { fetchOeuvres, fetchAPropos } from '../lib/strapi-client';
import { url } from '../lib/base-url';
import { HERO_HOME } from '../lib/image-presets';
import { buildArtGallerySchema, getSiteUrl } from '../lib/seo-utils';

const acquisitionsRecentes = await fetchOeuvres({ sort: 'createdAt:desc', limit: 8, hasVisuels: true });
const apropos = await fetchAPropos();
const oeuvresMisesEnAvant = apropos?.oeuvresMisesEnAvant ?? [];
const oeuvreHero = oeuvresMisesEnAvant[0] ?? acquisitionsRecentes[0] ?? null;
const visuelHero = oeuvreHero?.visuels?.[0] ?? null;

const siteUrl = getSiteUrl(Astro.site);
const schema = buildArtGallerySchema({ siteUrl, apropos });
---

<LayoutPrincipal
  title="Galerie Louis Barrand — Galerie d'art à Paris, XIXe-XXe siècles"
  description="Galerie d'art spécialisée dans la redécouverte d'artistes oubliés des XIXe et XXe siècles. Découvrez les dernières acquisitions, expositions et artistes."
  schema={schema}
>
  <section class="hero container--bleed">
    <div class="hero-media">
      {visuelHero ? (
        <a
          href={oeuvreHero ? url(`/oeuvres/${oeuvreHero.slug}`) : '#'}
          class="hero-image-link"
          aria-label={oeuvreHero ? `Voir l'œuvre : ${oeuvreHero.titre}` : undefined}
        >
          <Image
            src={visuelHero.url}
            alt={oeuvreHero ? `${oeuvreHero.titre}${oeuvreHero.artiste ? `, ${oeuvreHero.artiste.nom}` : ''}` : ''}
            width={visuelHero.width}
            height={visuelHero.height}
            widths={HERO_HOME.widths}
            sizes={HERO_HOME.sizes}
            loading="eager"
            fetchpriority="high"
            class="hero-img"
          />
        </a>
      ) : (
        <div class="hero-image-placeholder" aria-hidden="true"></div>
      )}
    </div>

    <div class="hero-texte">
      <p class="hero-surtitre">Tableaux — Dessins — Estampes XIX-XXème</p>
      <h1>Galerie<br />Louis Barrand</h1>
      <a href={url('/oeuvres')} class="hero-lien">Explorer la collection</a>
    </div>
  </section>

  {acquisitionsRecentes.length > 0 && (
    <section class="container--edge acquisitions-recentes">
      <p class="acquisitions-eyebrow">Une galerie consacrée à la redécouverte d'artistes oubliés des XIXᵉ et XXᵉ siècles, au cœur du 8ᵉ arrondissement de Paris.</p>
      <h2>Acquisitions récentes</h2>
      <ul class="grille-oeuvres">
        {acquisitionsRecentes.map((oeuvre) => (
          <li>
            <CarteOeuvre oeuvre={oeuvre} />
          </li>
        ))}
      </ul>
      <div class="voir-tout">
        <a href={url('/oeuvres')} class="cta-lien">
          Voir toutes les œuvres
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  )}
</LayoutPrincipal>

<style>
  /* ---- Hero ---- */

  .hero {
    position: relative;
    margin-bottom: var(--space-4xl);
  }

  .hero-media {
    position: relative;
    width: 100%;
  }

  .hero-image-link,
  .hero-image-placeholder {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  @media (min-width: 1280px) {
    .hero-image-link,
    .hero-image-placeholder {
      aspect-ratio: 16 / 9;
    }
  }

  .hero-image-placeholder {
    background: var(--color-border);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1200ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-image-link:hover .hero-img {
    transform: scale(1.02);
  }

  /* Texte sous l'image (mobile + iPad portrait) */
  .hero-texte {
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl) var(--gutter);
    background: var(--color-bg);
  }

  /* À partir d'une hauteur de hero suffisante, on superpose le texte */
  @media (min-width: 1280px) {
    .hero-texte {
      position: absolute;
      left: 0;
      bottom: 0;
      max-width: min(560px, 60vw);
      padding: var(--space-3xl) var(--gutter) var(--space-2xl);
      background: linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.15) 60%, rgba(0, 0, 0, 0) 100%);
      color: var(--color-bg);
    }
  }

  .hero-surtitre {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-lg);
  }

  @media (min-width: 1280px) {
    .hero-surtitre {
      font-size: 0.875rem;
      letter-spacing: 0.22em;
      color: var(--color-bg);
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
      margin-bottom: var(--space-xl);
    }
  }

  .hero-texte h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 6vw, 5.5rem);
    font-weight: 500;
    line-height: 1.0;
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 1280px) {
    .hero-texte h1 {
      color: var(--color-bg);
      text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
    }
  }

  .hero-lien {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    transition: color 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  @media (min-width: 1280px) {
    .hero-lien {
      color: var(--color-bg);
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
    }
  }

  .hero-lien::after {
    content: '→';
    transition: transform 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-lien:hover {
    color: var(--color-accent);
  }

  @media (min-width: 1280px) {
    .hero-lien:hover {
      color: var(--color-bg);
      opacity: 0.75;
    }
  }

  .hero-lien:hover::after {
    transform: translateX(6px);
  }

  /* ---- Acquisitions récentes ---- */

  .acquisitions-recentes {
    padding-bottom: var(--space-4xl);
  }

  .acquisitions-eyebrow {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 56ch;
    margin-bottom: var(--space-md);
  }

  .acquisitions-recentes h2 {
    margin-bottom: var(--space-3xl);
  }

  .grille-oeuvres {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .grille-oeuvres {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl);
    }
  }

  @media (min-width: 1280px) {
    .grille-oeuvres {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-2xl);
    }
  }

  @media (min-width: 1440px) {
    .grille-oeuvres {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-3xl);
    }
  }

  /* CTA "Voir toutes les œuvres" — lien souligné fin */
  .voir-tout {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  .cta-lien {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 4px;
    transition: color 400ms cubic-bezier(0.25, 0.1, 0.25, 1),
                border-color 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-lien span {
    transition: transform 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-lien:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .cta-lien:hover span {
    transform: translateX(4px);
  }
</style>
