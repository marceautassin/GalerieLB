---
import { Image } from 'astro:assets';
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import CarteOeuvre from '../components/CarteOeuvre.astro';
import { fetchOeuvres, fetchAPropos } from '../lib/strapi-client';
import { url } from '../lib/base-url';
import { HERO_HOME } from '../lib/image-presets';

const acquisitionsRecentes = await fetchOeuvres({ sort: 'createdAt:desc', limit: 8 });
const apropos = await fetchAPropos();
const oeuvresMisesEnAvant = apropos?.oeuvresMisesEnAvant ?? [];
const oeuvreHero = oeuvresMisesEnAvant[0] ?? acquisitionsRecentes[0] ?? null;
const visuelHero = oeuvreHero?.visuels?.[0] ?? null;
---

<LayoutPrincipal
  title="Galerie Louis Barrand — Tableaux, Dessins, Estampes XIXe-XXe"
  description="Galerie d'art spécialisée dans la redécouverte d'artistes oubliés des XIXe et XXe siècles. Découvrez les dernières acquisitions, expositions et artistes."
>
  <section class="hero">
    {visuelHero ? (
      <a
        href={oeuvreHero ? url(`/oeuvres/${oeuvreHero.slug}`) : '#'}
        class="hero-image-link"
        aria-label={oeuvreHero ? `Voir l'œuvre : ${oeuvreHero.titre}` : undefined}
      >
        <Image
          src={visuelHero.url}
          alt={oeuvreHero ? `${oeuvreHero.titre}${oeuvreHero.artiste ? `, ${oeuvreHero.artiste.nom}` : ''}` : ''}
          width={visuelHero.width}
          height={visuelHero.height}
          widths={HERO_HOME.widths}
          sizes={HERO_HOME.sizes}
          loading="eager"
          fetchpriority="high"
          class="hero-img"
        />
      </a>
    ) : (
      <div class="hero-image-placeholder" aria-hidden="true"></div>
    )}

    <div class="hero-texte">
      <p class="hero-surtitre">Tableaux — Dessins — Estampes XIX-XXème</p>
      <h1>Galerie<br />Louis Barrand</h1>
      <a href={url('/oeuvres')} class="hero-lien">Explorer la collection</a>
    </div>
  </section>

  {acquisitionsRecentes.length > 0 && (
    <section class="acquisitions-recentes">
      <h2>Acquisitions récentes</h2>
      <ul class="grille-oeuvres">
        {acquisitionsRecentes.map((oeuvre) => (
          <li>
            <CarteOeuvre oeuvre={oeuvre} />
          </li>
        ))}
      </ul>
      <div class="voir-tout">
        <a href={url('/oeuvres')} class="btn-primary">Voir toutes les œuvres</a>
      </div>
    </section>
  )}
</LayoutPrincipal>

<style>
  /* ---- Hero ---- */

  .hero {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 80vh;
    margin-bottom: var(--space-4xl);
    /* Full-bleed : sort du conteneur */
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 3fr 2fr;
      min-height: 85vh;
    }
  }

  /* Image */
  .hero-image-link,
  .hero-image-placeholder {
    display: block;
    overflow: hidden;
    min-height: 50vw;
  }

  @media (min-width: 768px) {
    .hero-image-link,
    .hero-image-placeholder {
      min-height: unset;
    }
  }

  .hero-image-placeholder {
    background: var(--color-border);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 800ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-image-link:hover .hero-img {
    transform: scale(1.03);
  }

  /* Texte */
  .hero-texte {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-2xl) var(--space-lg);
    background: var(--color-bg);
  }

  @media (min-width: 768px) {
    .hero-texte {
      padding: var(--space-4xl) var(--space-3xl);
      justify-content: center;
    }
  }

  .hero-surtitre {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-lg);
  }

  .hero-texte h1 {
    font-size: clamp(2.75rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
    margin-bottom: var(--space-2xl);
  }

  .hero-lien {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    transition: color 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-lien::after {
    content: '→';
    transition: transform 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-lien:hover {
    color: var(--color-accent);
  }

  .hero-lien:hover::after {
    transform: translateX(4px);
  }

  /* ---- Acquisitions récentes ---- */

  .acquisitions-recentes {
    padding-bottom: var(--space-4xl);
  }

  .acquisitions-recentes h2 {
    margin-bottom: var(--space-xl);
  }

  .grille-oeuvres {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .grille-oeuvres {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2xl);
    }
  }

  @media (min-width: 1024px) {
    .grille-oeuvres {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .voir-tout {
    text-align: center;
    margin-top: var(--space-2xl);
  }
</style>
