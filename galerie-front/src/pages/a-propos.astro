---
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { fetchAPropos } from '../lib/strapi-client';
import { url } from '../lib/base-url';

const apropos = await fetchAPropos();
const vuesGalerie = apropos?.vuesGalerie ?? [];
---

<LayoutPrincipal
  title="À propos — Galerie Louis Barrand"
  description="Découvrez le parcours de Louis Barrand, lauréat du Prix Marcus, et les informations pratiques de la Galerie Louis Barrand."
>
  <article class="page-a-propos">
    <Breadcrumb items={[
      { label: 'Accueil', href: url('/') },
      { label: 'À propos' },
    ]} />

    <h1>À propos</h1>

    {!apropos && (
      <p class="empty">Contenu en cours de rédaction.</p>
    )}

    {apropos?.biographieLouis && (
      <section class="section-biographie">
        <h2>Louis Barrand</h2>
        <div class="biographie-contenu">
          {apropos.photoLouis && (
            <img
              src={apropos.photoLouis.url}
              alt={apropos.photoLouis.alternativeText ?? 'Louis Barrand, galeriste'}
              class="biographie-photo"
              loading="eager"
              fetchpriority="high"
            />
          )}
          <div class="contenu-texte">
            {apropos.biographieLouis.split('\n').filter((p) => p.trim()).map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </div>
      </section>
    )}

    {apropos?.textePrixMarcus && (
      <section class="section-prix-marcus">
        <h2>Prix Marcus et expertise</h2>
        <div class="contenu-texte">
          {apropos.textePrixMarcus.split('\n').filter((p) => p.trim()).map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </section>
    )}

    {vuesGalerie.length > 0 && (
      <section class="section-galerie">
        <h2>La galerie</h2>
        <div class="galerie-vues">
          {vuesGalerie.slice(0, 3).map((img) => (
            <div class="galerie-vue">
              <img src={img.url} alt="Vue de la Galerie Louis Barrand" loading="lazy" />
            </div>
          ))}
        </div>
      </section>
    )}

    {(apropos?.adresse || apropos?.horaires || apropos?.telephone || apropos?.email) && (
      <section class="section-infos-pratiques">
        <h2>Informations pratiques</h2>
        <div class="infos-grid">
          {apropos.adresse && (
            <div class="info-bloc">
              <h3>Adresse</h3>
              <p>{apropos.adresse}</p>
            </div>
          )}
          {apropos.horaires && (
            <div class="info-bloc">
              <h3>Horaires</h3>
              <p>{apropos.horaires}</p>
            </div>
          )}
          {(apropos.telephone || apropos.email) && (
            <div class="info-bloc">
              <h3>Contact</h3>
              {apropos.telephone && (
                <p><a href={`tel:${apropos.telephone}`}>{apropos.telephone}</a></p>
              )}
              {apropos.email && (
                <p><a href={`mailto:${apropos.email}`}>{apropos.email}</a></p>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    <section class="section-liens-externes">
      <h2>Retrouvez-nous aussi sur</h2>
      <ul class="liens-externes-liste" role="list">
        <li>
          <a
            href="https://www.proantic.com/galerie/galerie-louis-barrand"
            target="_blank"
            rel="noopener"
            class="lien-externe"
          >
            Proantic &#8599;
          </a>
        </li>
        {apropos?.instagram && (
          <li>
            <a href={apropos.instagram} target="_blank" rel="noopener" class="lien-externe">
              Instagram &#8599;
            </a>
          </li>
        )}
        {apropos?.linkedin && (
          <li>
            <a href={apropos.linkedin} target="_blank" rel="noopener" class="lien-externe">
              LinkedIn &#8599;
            </a>
          </li>
        )}
      </ul>
    </section>
  </article>
</LayoutPrincipal>

<style>
  .page-a-propos {
    padding-bottom: var(--space-2xl);
  }

  .page-a-propos h1 {
    margin: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .empty {
    color: var(--color-text-secondary);
    text-align: center;
    padding: var(--space-2xl) 0;
  }

  .section-biographie,
  .section-prix-marcus,
  .section-infos-pratiques,
  .section-liens-externes {
    margin: 0 auto var(--space-2xl);
    max-width: 720px;
  }

  .section-biographie h2,
  .section-prix-marcus h2,
  .section-infos-pratiques h2,
  .section-liens-externes h2 {
    margin-bottom: var(--space-md);
  }

  .contenu-texte {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .contenu-texte p {
    margin-bottom: var(--space-md);
  }

  .biographie-contenu {
    display: block;
  }

  .biographie-photo {
    display: block;
    width: 60%;
    max-width: 240px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 25%;
    margin-bottom: var(--space-lg);
  }

  @media (min-width: 640px) and (max-width: 1023.98px) {
    .biographie-photo {
      float: left;
      width: 240px;
      max-width: 240px;
      margin-right: var(--space-lg);
      margin-bottom: var(--space-md);
    }

    .biographie-contenu::after {
      content: '';
      display: block;
      clear: both;
    }
  }

  @media (min-width: 1024px) {
    .biographie-contenu {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: var(--space-xl);
      align-items: start;
    }

    .biographie-photo {
      width: 100%;
      max-width: none;
      margin: 0;
    }
  }

  .liens-externes-liste {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
  }

  .infos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .infos-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .info-bloc h3 {
    margin-bottom: var(--space-xs);
  }

  .info-bloc p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    white-space: pre-line;
  }

  .info-bloc a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fade);
  }

  .info-bloc a:hover {
    color: var(--color-text);
  }

  /* Vues de la galerie */
  .section-galerie {
    margin: 0 auto var(--space-2xl);
    max-width: 720px;
  }

  .section-galerie h2 {
    margin-bottom: var(--space-md);
  }

  .galerie-vues {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 0 var(--space-lg);
  }

  @media (min-width: 640px) {
    .galerie-vues {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }
  }

  @media (min-width: 768px) {
    .galerie-vues {
      padding: 0 var(--space-2xl);
    }
  }

  @media (min-width: 1440px) {
    .galerie-vues {
      padding: 0;
      max-width: var(--max-width);
      margin-left: auto;
      margin-right: auto;
      width: 100%;
    }
  }

  .galerie-vue {
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }

  .galerie-vue img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lien-externe {
    display: inline-block;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    transition: color var(--transition-fade);
  }

  .lien-externe:hover {
    color: var(--color-text);
  }
</style>
