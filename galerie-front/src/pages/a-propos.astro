---
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { fetchAPropos } from '../lib/strapi-client';
import { url } from '../lib/base-url';

const apropos = await fetchAPropos();
const vuesGalerie = apropos?.vuesGalerie ?? [];
---

<LayoutPrincipal
  title="À propos — Galerie Louis Barrand"
  description="Découvrez le parcours de Louis Barrand, lauréat du Prix Marcus, et les informations pratiques de la Galerie Louis Barrand."
>
  <article class="page-a-propos">
    <Breadcrumb items={[
      { label: 'Accueil', href: url('/') },
      { label: 'À propos' },
    ]} />

    <h1>À propos</h1>

    {!apropos && (
      <p class="empty">Contenu en cours de rédaction.</p>
    )}

    {apropos?.biographieLouis && (
      <section class="section-biographie">
        <h2>Louis Barrand</h2>
        <div class="contenu-texte">
          {apropos.biographieLouis.split('\n').filter((p) => p.trim()).map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </section>
    )}

    {apropos?.textePrixMarcus && (
      <section class="section-prix-marcus">
        <h2>Prix Marcus et expertise</h2>
        <div class="contenu-texte">
          {apropos.textePrixMarcus.split('\n').filter((p) => p.trim()).map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </section>
    )}

    {vuesGalerie.length > 0 && (
      <div class="bandeau-galerie" aria-hidden="true">
        <div class="bandeau-track">
          {[...vuesGalerie, ...vuesGalerie].map((img) => (
            <div class="bandeau-item">
              <img src={img.url} alt="" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    )}

    {(apropos?.adresse || apropos?.horaires || apropos?.telephone || apropos?.email) && (
      <section class="section-infos-pratiques">
        <h2>Informations pratiques</h2>
        <div class="infos-grid">
          {apropos.adresse && (
            <div class="info-bloc">
              <h3>Adresse</h3>
              <p>{apropos.adresse}</p>
            </div>
          )}
          {apropos.horaires && (
            <div class="info-bloc">
              <h3>Horaires</h3>
              <p>{apropos.horaires}</p>
            </div>
          )}
          {(apropos.telephone || apropos.email) && (
            <div class="info-bloc">
              <h3>Contact</h3>
              {apropos.telephone && (
                <p><a href={`tel:${apropos.telephone}`}>{apropos.telephone}</a></p>
              )}
              {apropos.email && (
                <p><a href={`mailto:${apropos.email}`}>{apropos.email}</a></p>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    <section class="section-liens-externes">
      <h2>Retrouvez-nous aussi sur</h2>
      <a
        href="https://www.proantic.com/galerie/galerie-louis-barrand"
        target="_blank"
        rel="noopener"
        class="lien-externe"
      >
        Proantic &#8599;
      </a>
    </section>
  </article>
</LayoutPrincipal>

<style>
  .page-a-propos {
    padding-bottom: var(--space-2xl);
  }

  .page-a-propos h1 {
    margin: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .empty {
    color: var(--color-text-secondary);
    text-align: center;
    padding: var(--space-2xl) 0;
  }

  .section-biographie,
  .section-prix-marcus,
  .section-infos-pratiques,
  .section-liens-externes {
    margin: 0 auto var(--space-2xl);
    max-width: 720px;
  }

  .section-biographie h2,
  .section-prix-marcus h2,
  .section-infos-pratiques h2,
  .section-liens-externes h2 {
    margin-bottom: var(--space-md);
  }

  .contenu-texte {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .contenu-texte p {
    margin-bottom: var(--space-md);
  }

  .infos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .infos-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .info-bloc h3 {
    margin-bottom: var(--space-xs);
  }

  .info-bloc p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    white-space: pre-line;
  }

  .info-bloc a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fade);
  }

  .info-bloc a:hover {
    color: var(--color-text);
  }

  /* Bandeau déroulant — vues de la galerie */
  .bandeau-galerie {
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-bottom: var(--space-2xl);
  }

  .bandeau-track {
    display: flex;
    gap: var(--space-md);
    width: max-content;
    animation: defilement 40s linear infinite;
  }

  .bandeau-track:hover {
    animation-play-state: paused;
  }

  .bandeau-item {
    flex-shrink: 0;
    height: 240px;
    overflow: hidden;
  }

  .bandeau-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
  }

  @keyframes defilement {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (min-width: 768px) {
    .bandeau-item {
      height: 320px;
    }
  }

  .lien-externe {
    display: inline-block;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    transition: color var(--transition-fade);
  }

  .lien-externe:hover {
    color: var(--color-text);
  }
</style>
