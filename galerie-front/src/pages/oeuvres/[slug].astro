---
import type { GetStaticPaths } from 'astro';
import LayoutPrincipal from '../../layouts/LayoutPrincipal.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Lightbox from '../../components/Lightbox.astro';
import SectionLiensRelies from '../../components/SectionLiensRelies.astro';
import CarteOeuvre from '../../components/CarteOeuvre.astro';
import { fetchOeuvres, fetchOeuvresByArtiste } from '../../lib/strapi-client';
import { url } from '../../lib/base-url';
import { FICHE_OEUVRE } from '../../lib/image-presets';
import { buildVisualArtworkSchema, getSiteUrl } from '../../lib/seo-utils';

export const getStaticPaths: GetStaticPaths = async () => {
  const oeuvres = await fetchOeuvres();
  return oeuvres.map((oeuvre) => ({
    params: { slug: oeuvre.slug },
    props: { oeuvre },
  }));
};

const { oeuvre } = Astro.props;
const visuel = oeuvre.visuels?.[0];
const artisteNom = oeuvre.artiste?.nom ?? '';
const altText = artisteNom ? `${oeuvre.titre}, ${artisteNom}` : oeuvre.titre;

const memeArtiste = oeuvre.artiste?.slug
  ? await fetchOeuvresByArtiste(oeuvre.artiste.slug, {
      excludeSlug: oeuvre.slug,
      limit: 4,
    })
  : [];
const showMemeArtiste = memeArtiste.length >= 2;

function truncateAtWord(text: string, maxLen: number): string {
  if (text.length <= maxLen) return text;
  const truncated = text.slice(0, maxLen);
  const lastSpace = truncated.lastIndexOf(' ');
  return (lastSpace > 0 ? truncated.slice(0, lastSpace) : truncated) + '…';
}

const descParts = [oeuvre.titre];
if (artisteNom) descParts.push(artisteNom);
if (oeuvre.technique) descParts.push(oeuvre.technique);
if (oeuvre.dimensions) descParts.push(oeuvre.dimensions);
const description = truncateAtWord(descParts.join(' — '), 160);

const thematiques = (oeuvre.thematiques ?? []).map((t) => ({
  label: t.nom,
  href: url(`/oeuvres?thematique=${t.slug}`),
}));

const expositions = (oeuvre.expositions ?? []).map((e) => ({
  label: e.titre,
  href: url(`/expositions/${e.slug}`),
}));

const breadcrumbItems = [
  { label: 'Accueil', href: url('/') },
  { label: 'Œuvres', href: url('/oeuvres') },
];
if (oeuvre.artiste) {
  breadcrumbItems.push({ label: oeuvre.artiste.nom, href: url(`/artistes/${oeuvre.artiste.slug}`) });
}
breadcrumbItems.push({ label: oeuvre.titre });

const siteUrl = getSiteUrl(Astro.site);
const schema = buildVisualArtworkSchema({ siteUrl, oeuvre });
const titreSeo = artisteNom
  ? `${oeuvre.titre} — ${artisteNom} — Galerie Louis Barrand`
  : `${oeuvre.titre} — Galerie Louis Barrand`;
---

<LayoutPrincipal
  title={titreSeo}
  description={description}
  ogImage={visuel?.url}
  schema={schema}
>
  <article class="fiche-oeuvre-page container--edge">
    <Breadcrumb items={breadcrumbItems} />

    <div class="fiche-oeuvre">
      <div class="fiche-oeuvre-visuel">
        <div class="fiche-oeuvre-mur">
          {visuel ? (
            <Lightbox
              src={visuel.url}
              alt={altText}
              width={visuel.width}
              height={visuel.height}
              thumbWidths={FICHE_OEUVRE.widths}
              thumbSizes={FICHE_OEUVRE.sizes}
              loading="eager"
              fetchpriority="high"
            />
          ) : (
            <div class="fiche-oeuvre-placeholder" aria-hidden="true">
              <span>{oeuvre.titre.charAt(0)}</span>
            </div>
          )}
        </div>
      </div>

      <div class="fiche-oeuvre-meta">
        <h1>{oeuvre.titre}</h1>

        {oeuvre.artiste && (
          <p class="meta-artiste">
            <a href={url(`/artistes/${oeuvre.artiste.slug}`)}>{oeuvre.artiste.nom}</a>
          </p>
        )}

        <dl class="meta-details">
          {oeuvre.technique && (
            <>
              <dt>Technique</dt>
              <dd>{oeuvre.technique}</dd>
            </>
          )}
          {oeuvre.dimensions && (
            <>
              <dt>Dimensions</dt>
              <dd>{oeuvre.dimensions}</dd>
            </>
          )}
          {oeuvre.provenance && (
            <>
              <dt>Provenance</dt>
              <dd>{oeuvre.provenance}</dd>
            </>
          )}
        </dl>

        <a href={url(`/contact?oeuvre=${oeuvre.slug}`)} class="cta-rdv">
          Prendre rendez-vous
          <span aria-hidden="true">→</span>
        </a>

        <SectionLiensRelies
          titre="Thématiques"
          items={thematiques}
        />

        <SectionLiensRelies
          titre="Expositions"
          items={expositions}
          voirToutHref={url('/expositions')}
        />
      </div>
    </div>

    {showMemeArtiste && (
      <section class="section-meme-artiste">
        <h2>Du même artiste</h2>
        <ul class="grille-meme-artiste">
          {memeArtiste.map((o) => (
            <li><CarteOeuvre oeuvre={o} /></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</LayoutPrincipal>

<style>
  .fiche-oeuvre-page {
    padding-bottom: var(--space-2xl);
  }

  .fiche-oeuvre {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  @media (min-width: 900px) {
    .fiche-oeuvre {
      grid-template-columns: 5fr 3fr;
      gap: var(--space-2xl);
      align-items: start;
    }
  }

  .fiche-oeuvre-visuel {
    overflow: hidden;
  }

  .fiche-oeuvre-mur {
    background: var(--color-mur);
    padding: var(--space-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fiche-oeuvre-placeholder {
    aspect-ratio: 4 / 3;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-border);
    color: var(--color-text-tertiary);
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
  }

  .fiche-oeuvre-meta h1 {
    margin-bottom: var(--space-sm);
  }

  .meta-artiste {
    margin-bottom: var(--space-lg);
  }

  .meta-artiste a {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    transition: color 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .meta-artiste a:hover {
    color: var(--color-accent);
  }

  .meta-details {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .meta-details dt {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    font-weight: 600;
  }

  .meta-details dd {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .cta-rdv {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 4px;
    margin-bottom: var(--space-xl);
    transition: color 400ms cubic-bezier(0.25, 0.1, 0.25, 1),
                border-color 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-rdv:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .cta-rdv span {
    transition: transform 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-rdv:hover span {
    transform: translateX(4px);
  }

  .section-meme-artiste {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }

  .section-meme-artiste h2 {
    margin-bottom: var(--space-xl);
  }

  .grille-meme-artiste {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .grille-meme-artiste {
      /* auto-fill évite les colonnes vides quand l'artiste a 2-3 œuvres
         (au lieu de 4 colonnes étirées sur peu d'éléments). */
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
  }
</style>
