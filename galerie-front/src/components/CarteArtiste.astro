---
import { Image } from 'astro:assets';
import type { Artiste } from '../types/strapi';
import { url } from '../lib/base-url';
import { CARTE_GRILLE } from '../lib/image-presets';

interface Props {
  artiste: Artiste;
}

const { artiste } = Astro.props;
const hasPhoto = artiste.photo?.url;
---

<a href={url(`/artistes/${artiste.slug}`)} class="carte-artiste">
  <div class="carte-artiste-image">
    {hasPhoto ? (
      <Image
        src={artiste.photo!.url}
        alt={`Portrait de ${artiste.nom}`}
        width={artiste.photo!.width}
        height={artiste.photo!.height}
        widths={CARTE_GRILLE.widths}
        sizes={CARTE_GRILLE.sizes}
        loading="lazy"
      />
    ) : (
      <div class="carte-artiste-placeholder" aria-hidden="true">
        <span>{artiste.nom.charAt(0)}</span>
      </div>
    )}
  </div>
  <h2 class="carte-artiste-nom">{artiste.nom}</h2>
</a>

<style>
  .carte-artiste {
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  .carte-artiste:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .carte-artiste-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-border);
  }

  .carte-artiste-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .carte-artiste:hover .carte-artiste-image img {
    transform: scale(1.04);
  }

  .carte-artiste-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-border);
    color: var(--color-text-tertiary);
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 500;
  }

  .carte-artiste-nom {
    padding: var(--space-md) 0;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .carte-artiste:hover .carte-artiste-nom {
    color: var(--color-accent);
  }
</style>
