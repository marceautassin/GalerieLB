---
import { Image } from 'astro:assets';
import type { Oeuvre } from '../types/strapi';
import { url } from '../lib/base-url';
import { CARTE_GRILLE } from '../lib/image-presets';

interface Props {
  oeuvre: Oeuvre;
}

const { oeuvre } = Astro.props;
const visuel = oeuvre.visuels?.[0];
const artisteNom = oeuvre.artiste?.nom ?? '';
const altText = artisteNom ? `${oeuvre.titre}, ${artisteNom}` : oeuvre.titre;
---

<a href={url(`/oeuvres/${oeuvre.slug}`)} class="carte-oeuvre">
  <div class="carte-oeuvre-image">
    {visuel ? (
      <Image
        src={visuel.url}
        alt={altText}
        width={visuel.width}
        height={visuel.height}
        widths={CARTE_GRILLE.widths}
        sizes={CARTE_GRILLE.sizes}
        loading="lazy"
      />
    ) : (
      <div class="carte-oeuvre-placeholder" aria-hidden="true">
        <span>{oeuvre.titre.charAt(0)}</span>
      </div>
    )}
  </div>
  <div class="carte-oeuvre-info">
    <span class="carte-oeuvre-titre">{oeuvre.titre}</span>
    {artisteNom && <span class="carte-oeuvre-artiste">{artisteNom}</span>}
  </div>
</a>

<style>
  .carte-oeuvre {
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  .carte-oeuvre:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .carte-oeuvre-image {
    position: relative;
    overflow: hidden;
    background: var(--color-border);
  }

  .carte-oeuvre-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 800ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .carte-oeuvre:hover .carte-oeuvre-image img {
    transform: scale(1.02);
  }

  .carte-oeuvre-placeholder {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-border);
    color: var(--color-text-tertiary);
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
  }

  /* Info sous l'image, toujours visible (mobile + desktop) */
  .carte-oeuvre-info {
    display: flex;
    flex-direction: column;
    padding: var(--space-md) 0 var(--space-sm);
  }

  .carte-oeuvre-info .carte-oeuvre-titre {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .carte-oeuvre-info .carte-oeuvre-artiste {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-top: 4px;
  }
</style>
